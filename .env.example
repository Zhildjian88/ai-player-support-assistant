# ─────────────────────────────────────────────────────────────────────────────
# AI Player Support Assistant — Environment Configuration
#
# LOCAL DEV:
#   Copy to .env and fill in your values.
#   $ cp .env.example .env
#
# RENDER (production):
#   Do NOT commit .env to Git. Set these in the Railway dashboard:
#   Settings → Variables → Add variable
#   See DEPLOY.md for the full list of required Railway variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Groq is the default — free tier, no credit card needed.
# Sign up at https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# Anthropic — optional alternative
# Replace app/llm_service.py with app/llm_service_anthropic.py to use.
ANTHROPIC_API_KEY=

# ── LLM model ─────────────────────────────────────────────────────────────────
# Groq default:      llama-3.1-8b-instant   (fast, free tier)
# Groq alternative:  llama-3.3-70b-versatile (smarter, still free)
# Anthropic:         claude-haiku-4-5-20251001
LLM_MODEL=llama-3.1-8b-instant

# Maximum tokens per LLM response
LLM_MAX_TOKENS=512

# Enable or disable LLM fallback entirely (set false for deterministic-only testing)
ENABLE_LLM_FALLBACK=true

# LLM call timeout in seconds
LLM_TIMEOUT_SECONDS=10

# ── Semantic retrieval ────────────────────────────────────────────────────────
# false = TF-IDF lexical backend (default, no model download, Railway-compatible)
# true  = Neural embedding backend (paraphrase-multilingual-MiniLM-L12-v2, ~420 MB)
#         Not recommended for Railway free tier — use on local or paid infra only
USE_NEURAL_EMBEDDINGS=false

# Cosine similarity threshold (neural: 0.78 recommended, lexical: 0.25)
SIMILARITY_THRESHOLD=0.25

# ── Session context window ────────────────────────────────────────────────────
MAX_CONTEXT_TURNS=5

# ── Operational features ──────────────────────────────────────────────────────
ENABLE_AUDIT_LOG=true
ENABLE_ESCALATION=true

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/app.db
